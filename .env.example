# Kopiere diese Datei nach `.env` und trage deinen Schlüssel ein.
# Die Pipeline liest ANTHROPIC_API_KEY aus der Umgebung.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Standardmodell für die Analyse überschreiben.
# (Default: claude-haiku-4-5; Qualitätsoption: claude-sonnet-4-6)
# EP_MODEL=claude-sonnet-4-6
