  "summaries": [
    {
      "source_document": "Strafverfahren Epstein – Gerichtsakten / Berichterstattung (NPR, CBS), 2019–2025",
      "summary": "Jeffrey Epstein wurde im Juli 2019 von Bundesanwälten des Southern District of New York wegen Sexhandels mit Minderjährigen angeklagt (Vorwürfe betreffen die Jahre 2002–2005). Zuvor hatte es 2008 in Florida eine Nichtverfolgungsvereinbarung gegeben. Epstein starb am 10. August 2019 in Untersuchungshaft; der Tod wurde als Suizid eingestuft."
    },
    {
      "source_document": "Verfahren Maxwell – Gerichtsakten / Berichterstattung (Wikipedia, NPR), 2020–2022",
      "summary": "Ghislaine Maxwell wurde im Juli 2020 festgenommen und angeklagt. Nach einem Prozess (29. November bis 29. Dezember 2021) wurde sie in fünf von sechs Anklagepunkten schuldig gesprochen, darunter Sexhandel mit einer Minderjährigen. Im Juni 2022 wurde sie zu 20 Jahren Haft verurteilt. Alexander Acosta war als US-Bundesanwalt in Süd-Florida für die Nichtverfolgungsvereinbarung von 2008 verantwortlich."
    },
    {
      "source_document": "House Oversight Committee / DOJ-Freigabe 2025 (oversight.house.gov)",
      "summary": "Der US-Kongressausschuss für Aufsicht (House Oversight Committee) veröffentlichte 2025 vom Justizministerium (DOJ) übergebene Epstein-Akten. Laut Ausschuss umfasste die erste Tranche 33.295 Seiten (u. a. Flugprotokolle, Gerichtsdokumente, Vernehmungen); später kamen rund 20.000 Seiten aus Epsteins Nachlass hinzu. Opferidentitäten wurden geschwärzt."
    }
